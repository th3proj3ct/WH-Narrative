            <profile name="Loud Hailer" typeId="2c11-4ec5-60b9-9d46" typeName="Wargear" hidden="false" id="81ed-ee3b-41c5-2be1">
              <characteristics>
                <characteristic name="Summary" typeId="fdcc-276a-cadb-7810"/>
                <characteristic name="Description" typeId="516b-bc6f-e52f-aced">The Controlling Player may activate the loud hailer during the Start Phase of their Turn as the Active Player. When activated, the Controlling Player may make a Check to remove a single Tactical Status from any non-vehicle Adepta Sororitas units within 12&quot; of the Dialogus. This Check is made using the Characteristics of the Dialogus (using Cool, unless attempting to remove Routed, in which case Leadership is used). Each Friendly Model may only make a check once per Start Phase as part of this Special Rule.</characteristic>
              </characteristics>
            </profile>
          </profiles>
