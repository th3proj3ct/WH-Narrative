<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<catalogue library="false" id="d792-6578-20d7-7c56" name="Imperium - Adepta Sororitas" gameSystemId="sys-6b26-a652-2f51-d8fe" gameSystemRevision="1" revision="3" battleScribeVersion="2.03" type="catalogue" xmlns="http://www.battlescribe.net/schema/catalogueSchema">
  <sharedSelectionEntries>
    <selectionEntry type="upgrade" import="true" name="Simulacrum Imperialis" hidden="false" id="4ba3-70a1-f3e8-0589" sortIndex="99">
      <profiles>
        <profile name="Simulacrum Imperialis" typeId="2c11-4ec5-60b9-9d46" typeName="Wargear" hidden="false" id="1e78-dd13-d15c-7185">
          <characteristics>
            <characteristic name="Summary" typeId="fdcc-276a-cadb-7810">These holy symbols of the Ecclesiarchy were once carried by one of the Imperium’s many saints, or may even be wrought from their bones. They are wellsprings of inspiration and faith and it is a great honour to carry such an irreplaceable relic into battle.</characteristic>
            <characteristic name="Description" typeId="516b-bc6f-e52f-aced">If a model in this unit has a Simulacrum Imperialis, you may increase or decrease the value of a Miracle die uses for this unit by 1 (to a minimum of 1 and maximum of 6).</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Incensor Cherub" hidden="false" id="54a8-6f52-796e-0d06" sortIndex="99">
      <profiles>
        <profile name="Incensor Cherub" typeId="2c11-4ec5-60b9-9d46" typeName="Wargear" hidden="false" id="2f30-7def-b911-5185">
          <characteristics>
            <characteristic name="Summary" typeId="fdcc-276a-cadb-7810"/>
            <characteristic name="Description" typeId="516b-bc6f-e52f-aced">If a Unit that includes one or more Incensor Cherub, then whenever the Controlling Player fails a Check to remove a single Tactical Status from the unit, they can activate the Incensor Cherub.  If it does, that Incensor Cherub is removed from play and that unit can re-roll the result of the Check, ignoring all modifiers to it.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Armorium Cherub" hidden="false" id="f1c3-e882-9261-a04a" sortIndex="99">
      <profiles>
        <profile name="Armorium Cherub" typeId="2c11-4ec5-60b9-9d46" typeName="Wargear" hidden="false" id="a994-d536-c6ac-9b03">
          <characteristics>
            <characteristic name="Summary" typeId="fdcc-276a-cadb-7810"/>
            <characteristic name="Description" typeId="516b-bc6f-e52f-aced">If this unit has an Armorium Cherub, then after a model in this unit shoots with a ranged weapon, that Armorium Cherub can reload that model’s weapon. If it does, that Armorium Cherub is removed from play and that model can immediately shoot with that ranged weapon again.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
